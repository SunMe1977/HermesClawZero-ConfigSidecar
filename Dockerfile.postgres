# pgvector/pgvector:0.7.4-pg15
# Not :latest — prevents silent PG major version upgrades
# PG15 matches existing volume from previous pgvector image
FROM pgvector/pgvector:0.7.4-pg15

# Port
EXPOSE 5432

# Optional: eigenes Init-Script für Tabellen
# Alles, was in /docker-entrypoint-initdb.d liegt, wird beim ersten Start ausgeführt
COPY init.sql /docker-entrypoint-initdb.d/init.sql
