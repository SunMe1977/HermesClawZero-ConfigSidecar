# Usage: docker compose build --build-arg PG_BASE=pg17 db
#   pg17 = new installs (default)
#   pg15 = existing Windows volume (PG15 data)
ARG PG_BASE=pg17
FROM pgvector/pgvector:0.7.4-${PG_BASE}

# Port
EXPOSE 5432

# Optional: eigenes Init-Script für Tabellen
# Alles, was in /docker-entrypoint-initdb.d liegt, wird beim ersten Start ausgeführt
COPY init.sql /docker-entrypoint-initdb.d/init.sql
