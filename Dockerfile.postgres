# Basis: pgvector mit fester Version (nicht :latest!)
# Wichtig: :latest kann die PostgreSQL-Major-Version ändern und
# dadurch den Datenbank-Volume neu initialisieren (Datenverlust!).
# pgvector/pg17 bindet an PostgreSQL 17.
FROM pgvector/pgvector:0.8.0-pg17

# Port
EXPOSE 5432

# Optional: eigenes Init-Script für Tabellen
# Alles, was in /docker-entrypoint-initdb.d liegt, wird beim ersten Start ausgeführt
COPY init.sql /docker-entrypoint-initdb.d/init.sql
