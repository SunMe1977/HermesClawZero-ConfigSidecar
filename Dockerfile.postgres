# Basis: fertiges pgvector-Image
FROM ankane/pgvector:latest

# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB are provided
# via docker-compose environment (see docker-compose.yml / .env)

# Port
EXPOSE 5432

# Optional: eigenes Init-Script für Tabellen
# Alles, was in /docker-entrypoint-initdb.d liegt, wird beim ersten Start ausgeführt
COPY init.sql /docker-entrypoint-initdb.d/init.sql
