# Database Configuration
DB_HOST=gbrain-postgres
DB_PORT=5432
DB_NAME=gbrain
DB_USER=postgres
DB_PASSWORD=your_db_password

# AI Provider Selection
# Supported: ollama | openai | gemini | anthropic | openrouter
AI_PROVIDER=ollama
# Embedding backend used by /capture and /search. Use auto to map from AI_PROVIDER.
# Allowed: auto | ollama | openai | openrouter | gemini
EMBEDDING_PROVIDER=auto

# API & Security
# Required for protected API endpoints (capture/search/transcribe/etc.)
API_KEY=your_secret_api_key_here
# Change in production; do not use default values publicly.
DASHBOARD_PASSWORD=change_this_dashboard_password
# Optional: explicit signing key for dashboard sessions.
# DASHBOARD_SESSION_SECRET=change_this_session_secret

# External Provider API Keys (set only the one matching AI_PROVIDER)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENROUTER_EMBED_MODEL=text-embedding-3-small
GEMINI_EMBED_MODEL=models/text-embedding-004

# Memory API endpoint used by client/skills/sync workers
MEM_PUBLIC_URL=http://localhost:8010

# Versioning
APP_VERSION=0.1.0

# Update Management
AUTO_UPDATE_ENABLED=false
AUTO_UPDATE_APPLY=false
AUTO_UPDATE_INTERVAL_MINUTES=60
AUTO_UPDATE_REMOTE=origin
AUTO_UPDATE_BRANCH=main
UPDATE_REPO_DIR=/opt/HermesClawZero-ConfigSidecar
UPDATE_RESTART_COMMAND=
HERMES_DB_PATH=

# Infrastructure
OLLAMA_HOST=http://host.docker.internal:11434
MEM_SYNC_DIR=./sync

# Backward compatibility aliases (optional)
# OPENCLAW_URL=
# OPENCLAW_KEY=
# OPENCLAW_SYNC_DIR=
