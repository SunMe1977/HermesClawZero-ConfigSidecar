# Database Configuration
DB_HOST=gbrain-postgres
DB_PORT=5432
DB_NAME=gbrain
DB_USER=postgres
DB_PASSWORD=your_db_password

# API & Security
API_URL=http://localhost:8000
API_KEY=your_secret_api_key_here

# Infrastructure (host port 11435 is mapped to the Ollama container, see docker-compose.yml)
OLLAMA_HOST=http://host.docker.internal:11435
SYNC_DIR=./sync
