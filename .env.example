# Database Configuration
DB_HOST=gbrain-postgres
DB_PORT=5432
DB_NAME=gbrain
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# AI Provider Selection
# Supported: ollama | openai | gemini | anthropic | openrouter
AI_PROVIDER=ollama
# Embedding backend used by /capture and /search. Auto maps from AI_PROVIDER.
# Allowed: auto | ollama | openai | openrouter | gemini
EMBEDDING_PROVIDER=auto

# API & Security
# Required for all protected API endpoints (capture/search/etc.)
API_KEY=your_secret_api_key_here
DASHBOARD_PASSWORD=change_this_dashboard_password
# Optional: explicit signing key for dashboard sessions
# DASHBOARD_SESSION_SECRET=change_this_session_secret

# External Provider API Keys (set only the one matching AI_PROVIDER)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENROUTER_EMBED_MODEL=text-embedding-3-small
GEMINI_EMBED_MODEL=models/text-embedding-004

# Memory API endpoint used by client scripts (memory.py, memory_sync.py, skills)
# Default: http://localhost:8010
MEM_PUBLIC_URL=http://localhost:8010

# Ollama endpoint (Docker: host.docker.internal:11434, Windows native: localhost:11434)
OLLAMA_HOST=http://host.docker.internal:11434

# Optional: Telegram bot for notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Sync directory for memory_sync.py watchdog
MEM_SYNC_DIR=./sync

# Version
APP_VERSION=0.1.0

# Update Management
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_APPLY=true
AUTO_UPDATE_INTERVAL_MINUTES=60
AUTO_UPDATE_REMOTE=origin
AUTO_UPDATE_BRANCH=main
UPDATE_REPO_DIR=/opt/HermesClawZero-ConfigSidecar
# Auto-Recovery: before rebuild, backups all pages to persistent volume
# Restore runs automatically on startup if DB has < 100 pages.
# To run manually: docker exec -it hc-sidecar-api1-1 python /app/repo/migrations/pre_rebuild_backup.py backup
UPDATE_RESTART_COMMAND=python /app/repo/migrations/pre_rebuild_backup.py backup && docker compose down && docker compose up -d --build
HERMES_DB_PATH=

# Connection Pool (2M scale)
DB_POOL_MIN=10
DB_POOL_MAX=100
DB_POOL_TIMEOUT=30

# Async Embedding Queue (2M scale)
EMBED_BATCH_SIZE=10
EMBED_BATCH_INTERVAL=0.5

# Embedding dimension — uncomment and set for non-Ollama providers:
#   OpenRouter/OpenAI → 1536, Gemini → 768
# Leave empty for Ollama (auto-detect)
# EMBEDDING_DIM=1536

# Allow schema reset if embedding dimension changes (safe: only drops embeddings table, not pages)
ALLOW_EMBEDDING_SCHEMA_RESET=true
